---
interface Props {
    plan: string;
    precio: string;
    activacion: string;
    link: string;
    des1: string;
    des2: string;
    des3: string;
}

const { plan, precio, activacion, link, des1, des2, des3 } = Astro.props;
---

<section class="p-5">
    <p class="text-white uppercase font-light text-sm tracking-widest">
        Plan {plan}
    </p>
    <p class="text-white mt-5">
        <span class="text-4xl font-semibold">{precio}</span><span
            class="text-xs">.00/mes</span>
    </p>
    <p class="text-is-gradient font-semibold text-sm">{activacion}</p>

    <ul class="mt-5">
        <li class="flex items-center">
            <img
                src="../img/PhCircleFill.svg"
                class="mr-1"
                width="10"
                height="10"
                alt="Circle"
            />
            <p class="text-white text-sm"><strong>{des1}</strong> oyentes</p>
        </li>
        <li class="flex items-center">
            <img
                src="../img/PhCircleFill.svg"
                class="mr-1"
                width="10"
                height="10"
                alt="Circle"
            />
            <p class="text-white text-sm">Hasta <strong>{des2}</strong></p>
        </li>
        <li class="flex items-center">
            <img
                src="../img/PhCircleFill.svg"
                class="mr-1"
                width="10"
                height="10"
                alt="Circle"
            />
            <p class="text-white text-sm">Tranferencia Ilimitada</p>
        </li>
        <li class="flex items-center">
            <img
                src="../img/PhCircleFill.svg"
                class="mr-1"
                width="10"
                height="10"
                alt="Circle"
            />
            <p class="text-white text-sm">Compatible con SSL</p>
        </li>
        <li class="flex items-center">
            <img
                src="../img/PhCircleFill.svg"
                class="mr-1"
                width="10"
                height="10"
                alt="Circle"
            />
            <p class="text-white text-sm"><strong>{des3}</strong> AutoDJ</p>
        </li>
        <li class="flex items-center">
            <img
                src="../img/PhCircleFill.svg"
                class="mr-1"
                width="10"
                height="10"
                alt="Circle"
            />
            <p class="text-white text-sm">Soporte para móviles</p>
        </li>
        <li class="flex items-center">
            <img
                src="../img/PhCircleFill.svg"
                class="mr-1"
                width="10"
                height="10"
                alt="Circle"
            />
            <p class="text-white text-sm">Reproductor HTML5</p>
        </li>
        <li class="flex items-center">
            <img
                src="../img/PhCircleFill.svg"
                class="mr-1"
                width="10"
                height="10"
                alt="Circle"
            />
            <p class="text-white text-sm">Shoutcast</p>
        </li>
        <li class="flex items-center">
            <img
                src="../img/PhCircleFill.svg"
                class="mr-1"
                width="10"
                height="10"
                alt="Circle"
            />
            <p class="text-white text-sm">Panel de Control</p>
        </li>
        <li class="flex items-center">
            <img
                src="../img/PhCircleFill.svg"
                class="mr-1"
                width="10"
                height="10"
                alt="Circle"
            />
            <p class="text-white text-sm">App Android (aplica restricciones)</p>
        </li>
    </ul>

    <a
    href={link}
    class="mt-10 relative inline-flex items-center justify-center p-0.5 overflow-hidden text-sm font-medium text-gray-900 rounded-lg group bg-gradient-to-br from-purple-600 to-blue-500 group-hover:from-purple-600 group-hover:to-blue-500 hover:text-white dark:text-white focus:ring-4 focus:outline-none focus:ring-blue-300 dark:focus:ring-blue-800"
>
    <span
        class="textos relative px-5 py-2.5 transition-all ease-in duration-75 bg-white dark:bg-gray-900 rounded-md group-hover:bg-opacity-0"
    >
        Realizar Pedido
    </span>
</a>
    <a
        href={`https://wa.me/593991220769?text=Hola%2C+me+interesa+el+${encodeURIComponent('Plan ' + plan)}+de+CentovaCast`}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1.5 text-xs text-gray-400 hover:text-[#25D366] mt-3 transition-colors"
    >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        Consultar por WhatsApp
    </a>
</section>

<style>
    .text-is-gradient {
        background-image: linear-gradient(
            to right,
            var(--gradient-text) 11%,
            var(--gradient-color-2)
        );
        -webkit-text-fill-color: transparent;
        -webkit-background-clip: text;
        background-clip: text;
    }

     .textos{
    font-family: "IBM Plex Mono", monospace;
    text-transform: uppercase;
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 2px;
     }

</style>

