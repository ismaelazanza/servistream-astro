---
import Layout from "../layouts/Layout.astro";
import Top from "../components/Top.astro";
import Menu from "../components/Menu.astro";
import MobileMenu from "../components/MobilMenu.astro";
import Footer from "../components/Footer.astro";
import ServiciosRelacionados from "../components/ServiciosRelacionados.astro";

const serviceSchema = {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Hosting Web Guayaquil Ecuador",
    "description": "Hosting web profesional para empresas en Guayaquil. cPanel, SSL gratis, soporte 24/7. Desde $2.30/mes.",
    "url": "https://servistream.net/hosting-guayaquil/",
    "provider": { "@type": "Organization", "name": "ServiStream", "url": "https://servistream.net" },
    "areaServed": { "@type": "City", "name": "Guayaquil", "containedInPlace": { "@type": "Country", "name": "Ecuador" } },
    "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Planes Hosting Guayaquil",
        "itemListElement": [
            { "@type": "Offer", "name": "Plan Deluxe", "price": "2.30", "priceCurrency": "USD" },
            { "@type": "Offer", "name": "Plan Ultimate", "price": "2.75", "priceCurrency": "USD" },
            { "@type": "Offer", "name": "Plan Maximum", "price": "3.33", "priceCurrency": "USD" }
        ]
    }
};
---

<Layout
    title="Hosting Web Guayaquil Ecuador - Desde $2.30/mes | ServiStream"
    description="Hosting web profesional para empresas en Guayaquil, Ecuador. cPanel, SSL gratis, CloudLinux, soporte técnico 24/7. Planes desde $2.30/mes. Actívate hoy."
    schema={serviceSchema}
>
    <header class="css-selector">
        <Top />
        <div class="hidden lg:block"><Menu /></div>
        <div class="pt-4 lg:hidden"><MobileMenu /></div>

        <div class="contenedor mx-auto text-center flex flex-col items-center justify-center py-20 px-5">
            <p class="text-white text-sm font-semibold bg-[#00b285] inline-block px-4 py-1 rounded-full mb-6 uppercase tracking-widest">
                Guayaquil, Ecuador
            </p>
            <h1 class="text-white text-4xl font-bold pb-5 md:text-5xl lg:text-6xl">
                Hosting Web en Guayaquil
            </h1>
            <p class="text-white text-lg max-w-2xl pb-8">
                Impulsa tu empresa en Guayaquil con hosting web de alto rendimiento. Servidores NvMe ultrarrápidos,
                cPanel, SSL gratis y soporte técnico especializado las 24 horas del día.
            </p>
            <div class="flex flex-col items-center gap-4 md:flex-row">
                <a
                    href="https://clientes.servistream.net/index.php?rp=/store/web-hosting-linux/deluxe-plan"
                    class="bg-[#00b285] hover:bg-[#00966f] text-white font-bold py-3 px-8 rounded-lg transition-colors"
                >
                    Activar Hosting Ahora
                </a>
                <a
                    href="https://wa.me/593991220769?text=Hola%2C%20necesito%20hosting%20web%20en%20Guayaquil"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="border border-white text-white hover:bg-white hover:text-gray-900 font-semibold py-3 px-8 rounded-lg transition-colors"
                >
                    Consultar por WhatsApp
                </a>
            </div>
        </div>
    </header>

    <!-- Diferenciadores locales -->
    <section class="contenedor mx-auto px-5 py-20">
        <h2 class="text-3xl font-bold text-center mb-4">
            Hosting web para negocios en Guayaquil
        </h2>
        <p class="text-center text-gray-600 max-w-2xl mx-auto mb-12">
            Empresas, emprendedores y medios de comunicación en Guayaquil confían en ServiStream
            para tener una presencia digital profesional, rápida y sin interrupciones.
        </p>

        <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
            <div class="text-center p-6 rounded-xl border border-gray-100 hover:border-[#00b285] transition-colors">
                <div class="text-4xl font-black text-[#00b285] mb-3">99.9%</div>
                <h3 class="font-bold text-lg mb-2">Uptime Garantizado</h3>
                <p class="text-gray-500 text-sm">Infraestructura cloud redundante para que tu sitio web en Guayaquil nunca se caiga.</p>
            </div>
            <div class="text-center p-6 rounded-xl border border-gray-100 hover:border-[#00b285] transition-colors">
                <div class="text-4xl font-black text-[#00b285] mb-3">24/7</div>
                <h3 class="font-bold text-lg mb-2">Soporte Técnico</h3>
                <p class="text-gray-500 text-sm">Atención inmediata para tu empresa en Guayaquil, todos los días, a cualquier hora.</p>
            </div>
            <div class="text-center p-6 rounded-xl border border-gray-100 hover:border-[#00b285] transition-colors">
                <div class="text-4xl font-black text-[#00b285] mb-3">$2.30</div>
                <h3 class="font-bold text-lg mb-2">Desde por mes</h3>
                <p class="text-gray-500 text-sm">Planes accesibles con todo lo que necesitas para crecer digitalmente en Guayaquil.</p>
            </div>
        </div>
    </section>

    <!-- Planes -->
    <section class="bg-gray-50 py-20 px-5">
        <div class="contenedor mx-auto">
            <h2 class="text-3xl font-bold text-center mb-4">Planes de hosting para Guayaquil</h2>
            <p class="text-center text-gray-600 mb-12">SSL gratis, cPanel, backups diarios y migración incluida.</p>

            <div class="grid grid-cols-1 gap-6 md:grid-cols-3 max-w-4xl mx-auto">
                <div class="bg-white rounded-xl p-8 border border-gray-200 text-center">
                    <h3 class="font-bold text-xl mb-2">Plan Deluxe</h3>
                    <div class="text-4xl font-black text-[#00b285] mb-1">$2.30<span class="text-base font-normal text-gray-500">/mes</span></div>
                    <ul class="text-sm text-gray-600 text-left space-y-2 mt-6 mb-8">
                        <li>✓ 10 GB espacio SSD</li>
                        <li>✓ 1 dominio</li>
                        <li>✓ 20 correos empresariales</li>
                        <li>✓ SSL gratis</li>
                        <li>✓ cPanel incluido</li>
                    </ul>
                    <a href="https://clientes.servistream.net/index.php?rp=/store/web-hosting-linux/deluxe-plan" class="block bg-[#00b285] hover:bg-[#00966f] text-white font-semibold py-2 px-6 rounded-lg transition-colors">Contratar</a>
                </div>
                <div class="bg-white rounded-xl p-8 border-2 border-[#00b285] text-center relative">
                    <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[#00b285] text-white text-xs font-bold px-3 py-1 rounded-full">MÁS POPULAR</span>
                    <h3 class="font-bold text-xl mb-2">Plan Ultimate</h3>
                    <div class="text-4xl font-black text-[#00b285] mb-1">$2.75<span class="text-base font-normal text-gray-500">/mes</span></div>
                    <ul class="text-sm text-gray-600 text-left space-y-2 mt-6 mb-8">
                        <li>✓ 25 GB espacio SSD</li>
                        <li>✓ 1 dominio</li>
                        <li>✓ 30 correos empresariales</li>
                        <li>✓ SSL gratis</li>
                        <li>✓ 20 bases de datos MySQL</li>
                    </ul>
                    <a href="https://clientes.servistream.net/index.php?rp=/store/web-hosting-linux/ultimate-plan" class="block bg-[#00b285] hover:bg-[#00966f] text-white font-semibold py-2 px-6 rounded-lg transition-colors">Contratar</a>
                </div>
                <div class="bg-white rounded-xl p-8 border border-gray-200 text-center">
                    <h3 class="font-bold text-xl mb-2">Plan Maximum</h3>
                    <div class="text-4xl font-black text-[#00b285] mb-1">$3.33<span class="text-base font-normal text-gray-500">/mes</span></div>
                    <ul class="text-sm text-gray-600 text-left space-y-2 mt-6 mb-8">
                        <li>✓ 50 GB espacio SSD</li>
                        <li>✓ 1 dominio</li>
                        <li>✓ 50 correos empresariales</li>
                        <li>✓ SSL gratis</li>
                        <li>✓ 50 bases de datos MySQL</li>
                    </ul>
                    <a href="https://clientes.servistream.net/index.php?rp=/store/web-hosting-linux/maximum-plan" class="block bg-[#00b285] hover:bg-[#00966f] text-white font-semibold py-2 px-6 rounded-lg transition-colors">Contratar</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Incluido -->
    <section class="contenedor mx-auto px-5 py-20">
        <h2 class="text-2xl font-bold text-center mb-12">Todo incluido para tu empresa en Guayaquil</h2>
        <div class="grid grid-cols-2 gap-4 md:grid-cols-4 max-w-3xl mx-auto">
            {[
                "SSL gratis",
                "cPanel",
                "CloudLinux",
                "Jetbackup",
                "WordPress 1-clic",
                "Migración gratis",
                "Correo empresarial",
                "Soporte 24/7"
            ].map(item => (
                <div class="flex items-center gap-2 p-3 rounded-lg bg-gray-50">
                    <span class="text-[#00b285] font-bold">✓</span>
                    <span class="text-sm font-medium">{item}</span>
                </div>
            ))}
        </div>
    </section>

    <!-- CTA WhatsApp -->
    <section class="bg-[#0e141b] py-16 px-5">
        <div class="contenedor mx-auto text-center">
            <h2 class="text-white text-2xl font-bold mb-4">¿Necesitas hosting para tu empresa en Guayaquil?</h2>
            <p class="text-gray-400 mb-8">Nuestro equipo te asesora sin compromiso y te ayuda a elegir el plan ideal.</p>
            <a
                href="https://wa.me/593991220769?text=Hola%2C%20quiero%20hosting%20web%20para%20mi%20empresa%20en%20Guayaquil"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-3 bg-[#25D366] hover:bg-[#1ebe5a] text-white font-bold py-3 px-8 rounded-full text-lg transition-colors"
            >
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                </svg>
                Hablar con un asesor
            </a>
        </div>
    </section>

    <ServiciosRelacionados enlaces={[
        { href: "/hosting-linux/", titulo: "Hosting Linux cPanel Ecuador", descripcion: "Todos los planes de hosting compartido con cPanel, SSL y CloudLinux." },
        { href: "/hosting-cloud/", titulo: "Hosting Cloud Ecuador", descripcion: "Recursos dedicados garantizados para sitios con mayor tráfico." },
        { href: "/hosting-quito/", titulo: "Hosting Web Quito", descripcion: "Hosting profesional para empresas en Quito desde $2.30/mes." }
    ]} />
    <Footer />
</Layout>

<style lang="scss">
    header {
        background-color: #0e141b;
        background-image: linear-gradient(135deg, #0e141b 0%, #19322e 50%, #0e141b 100%);
    }
</style>
