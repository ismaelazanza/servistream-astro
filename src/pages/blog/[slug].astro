---
import Layout from "../../layouts/Layout.astro";
import Top from "../../components/Top.astro";
import Menu from "../../components/Menu.astro";
import MobileMenu from "../../components/MobilMenu.astro";
import Footer from "../../components/Footer.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
    const posts = await getCollection("blog");
    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const articleSchema = {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": post.data.title,
    "description": post.data.description,
    "datePublished": post.data.pubDate.toISOString(),
    "dateModified": post.data.pubDate.toISOString(),
    "author": {
        "@type": "Organization",
        "name": "ServiStream",
        "url": "https://servistream.net"
    },
    "publisher": {
        "@type": "Organization",
        "name": "ServiStream",
        "logo": {
            "@type": "ImageObject",
            "url": "https://servistream.net/img/LOGO-SERVISTREAM-NUEVO4.svg"
        }
    },
    "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": `https://servistream.net/blog/${post.id}/`
    }
};

const formattedDate = new Date(post.data.pubDate).toLocaleDateString('es-EC', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
});
---

<Layout
    title={`${post.data.title} | Blog ServiStream`}
    description={post.data.description}
    schema={articleSchema}
>
    <header class="article-header">
        <Top />
        <div class="hidden lg:block"><Menu /></div>
        <div class="pt-4 lg:hidden"><MobileMenu /></div>

        <div class="contenedor mx-auto px-5 py-4">
            <nav aria-label="Breadcrumb">
                <ol class="flex flex-wrap items-center gap-1 text-sm">
                    <li class="flex items-center gap-1">
                        <a href="/" class="text-gray-400 hover:text-white transition-colors">Inicio</a>
                    </li>
                    <li class="flex items-center gap-1">
                        <span class="text-gray-400">/</span>
                        <a href="/blog/" class="text-gray-400 hover:text-white transition-colors">Blog</a>
                    </li>
                    <li class="flex items-center gap-1">
                        <span class="text-gray-400">/</span>
                        <span class="text-gray-200 truncate max-w-[200px]">{post.data.title}</span>
                    </li>
                </ol>
            </nav>
        </div>

        <div class="contenedor mx-auto px-5 py-12">
            <div class="max-w-3xl">
                <div class="flex items-center gap-3 mb-4">
                    <span class="text-xs font-semibold text-[#00b285] uppercase tracking-widest">
                        {post.data.category}
                    </span>
                    <span class="text-gray-500">·</span>
                    <time class="text-sm text-gray-400" datetime={post.data.pubDate.toISOString()}>
                        {formattedDate}
                    </time>
                    <span class="text-gray-500">·</span>
                    <span class="text-sm text-gray-400">Por {post.data.author}</span>
                </div>
                <h1 class="text-white text-3xl font-bold leading-tight md:text-4xl lg:text-5xl">
                    {post.data.title}
                </h1>
                <p class="text-gray-300 text-lg mt-4 leading-relaxed">
                    {post.data.description}
                </p>
                <div class="flex flex-wrap gap-2 mt-6">
                    {post.data.tags.map(tag => (
                        <span class="text-xs bg-gray-800 text-gray-300 px-3 py-1 rounded-full">
                            #{tag}
                        </span>
                    ))}
                </div>
            </div>
        </div>
    </header>

    <!-- Artículo -->
    <article class="contenedor mx-auto px-5 py-16 max-w-3xl">
        <div class="prose-servistream">
            <Content />
        </div>
    </article>

    <!-- CTA lateral / final -->
    <aside class="bg-gray-50 py-12 px-5">
        <div class="contenedor mx-auto max-w-3xl">
            <div class="bg-[#0e141b] rounded-2xl p-8 text-center">
                <p class="text-[#00b285] text-sm font-semibold uppercase tracking-widest mb-3">ServiStream Ecuador</p>
                <h2 class="text-white text-2xl font-bold mb-3">¿Listo para empezar?</h2>
                <p class="text-gray-400 mb-6">Activa tu hosting o streaming en minutos. Soporte 24/7 incluido.</p>
                <div class="flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
                    <a
                        href="/hosting-linux/"
                        class="bg-[#00b285] hover:bg-[#00966f] text-white font-bold py-2.5 px-6 rounded-lg transition-colors"
                    >
                        Ver planes de Hosting
                    </a>
                    <a
                        href="https://wa.me/593991220769"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-2 bg-[#25D366] hover:bg-[#1ebe5a] text-white font-semibold py-2.5 px-6 rounded-lg transition-colors"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                        </svg>
                        WhatsApp
                    </a>
                </div>
            </div>
        </div>
    </aside>

    <!-- Navegación de artículos -->
    <div class="contenedor mx-auto px-5 py-8 border-t border-gray-100">
        <a href="/blog/" class="text-sm font-semibold text-[#00b285] hover:underline">
            ← Ver todos los artículos
        </a>
    </div>

    <Footer />
</Layout>

<style lang="scss">
    .article-header {
        background-color: #0e141b;
        background-image: linear-gradient(180deg, #1e1b3d 0%, #0e141b 100%);
    }

    /* Estilos del contenido Markdown */
    .prose-servistream {
        :global(h2) {
            font-size: 1.75rem;
            font-weight: 700;
            margin-top: 2.5rem;
            margin-bottom: 1rem;
            border-bottom: 2px solid #f3f4f6;
            padding-bottom: 0.5rem;
        }
        :global(h3) {
            font-size: 1.25rem;
            font-weight: 700;
            margin-top: 2rem;
            margin-bottom: 0.75rem;
        }
        :global(p) {
            line-height: 1.8;
            margin-bottom: 1.25rem;
            color: #374151;
        }
        :global(ul), :global(ol) {
            margin: 1rem 0 1.5rem 1.5rem;
            line-height: 1.8;
        }
        :global(li) {
            margin-bottom: 0.5rem;
            color: #374151;
        }
        :global(strong) {
            color: #111827;
        }
        :global(a) {
            color: #00b285;
            text-decoration: underline;
            &:hover { color: #00966f; }
        }
        :global(table) {
            width: 100%;
            border-collapse: collapse;
            margin: 1.5rem 0;
            font-size: 0.9rem;
        }
        :global(th) {
            background-color: #f9fafb;
            font-weight: 700;
            padding: 0.75rem 1rem;
            text-align: left;
            border: 1px solid #e5e7eb;
        }
        :global(td) {
            padding: 0.75rem 1rem;
            border: 1px solid #e5e7eb;
            color: #374151;
        }
        :global(tr:nth-child(even)) {
            background-color: #f9fafb;
        }
        :global(code) {
            background-color: #f3f4f6;
            padding: 0.2em 0.4em;
            border-radius: 4px;
            font-size: 0.875em;
            color: #1e1b3d;
        }
        :global(pre) {
            background-color: #1e1b3d;
            color: #e5e7eb;
            padding: 1.5rem;
            border-radius: 0.75rem;
            overflow-x: auto;
            margin: 1.5rem 0;
            :global(code) {
                background: none;
                padding: 0;
                color: inherit;
            }
        }
        :global(blockquote) {
            border-left: 4px solid #00b285;
            padding-left: 1.25rem;
            margin: 1.5rem 0;
            color: #6b7280;
            font-style: italic;
        }
    }
</style>
