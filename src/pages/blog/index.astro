---
import Layout from "../../layouts/Layout.astro";
import Top from "../../components/Top.astro";
import Menu from "../../components/Menu.astro";
import MobileMenu from "../../components/MobilMenu.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");
const posts = allPosts.sort((a, b) =>
    new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

const blogSchema = {
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "Blog ServiStream - Hosting y Streaming Ecuador",
    "description": "Guías, tutoriales y noticias sobre hosting web, streaming de radio, dominios y páginas web en Ecuador.",
    "url": "https://servistream.net/blog/",
    "publisher": {
        "@type": "Organization",
        "name": "ServiStream",
        "url": "https://servistream.net"
    }
};
---

<Layout
    title="Blog ServiStream - Guías de Hosting y Streaming Ecuador"
    description="Guías prácticas, tutoriales y consejos sobre hosting web, radio streaming, TV online y páginas web en Ecuador. Aprende de los expertos."
    schema={blogSchema}
>
    <header class="blog-header">
        <Top />
        <div class="hidden lg:block"><Menu /></div>
        <div class="pt-4 lg:hidden"><MobileMenu /></div>

        <div class="contenedor mx-auto text-center py-20 px-5">
            <p class="text-white text-sm font-semibold bg-[#00b285] inline-block px-4 py-1 rounded-full mb-6 uppercase tracking-widest">
                Recursos y Guías
            </p>
            <h1 class="text-white text-4xl font-bold pb-4 md:text-5xl">
                Blog ServiStream
            </h1>
            <p class="text-white text-lg max-w-2xl mx-auto">
                Guías prácticas, tutoriales y consejos sobre hosting web, radio streaming y presencia digital en Ecuador.
            </p>
        </div>
    </header>

    <section class="contenedor mx-auto px-5 py-20">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
            {posts.map((post) => (
                <article class="group rounded-xl border border-gray-200 overflow-hidden hover:border-[#00b285] hover:shadow-lg transition-all ease-out">
                    <a href={`/blog/${post.id}/`} class="block">
                        <div class="p-6">
                            <div class="flex items-center gap-2 mb-3">
                                <span class="text-xs font-semibold text-[#00b285] uppercase tracking-widest">
                                    {post.data.category}
                                </span>
                                <span class="text-gray-300">·</span>
                                <time
                                    class="text-xs text-gray-400"
                                    datetime={post.data.pubDate.toISOString()}
                                >
                                    {new Date(post.data.pubDate).toLocaleDateString('es-EC', {
                                        year: 'numeric',
                                        month: 'long',
                                        day: 'numeric'
                                    })}
                                </time>
                            </div>
                            <h2 class="font-bold text-xl mb-3 group-hover:text-[#00b285] transition-colors leading-snug">
                                {post.data.title}
                            </h2>
                            <p class="text-gray-500 text-sm leading-relaxed line-clamp-3">
                                {post.data.description}
                            </p>
                        </div>
                        <div class="px-6 pb-6">
                            <div class="flex flex-wrap gap-2 mb-4">
                                {post.data.tags.slice(0, 3).map(tag => (
                                    <span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded-full">
                                        #{tag}
                                    </span>
                                ))}
                            </div>
                            <span class="text-sm font-semibold text-[#00b285] group-hover:underline">
                                Leer artículo →
                            </span>
                        </div>
                    </a>
                </article>
            ))}
        </div>
    </section>

    <!-- CTA -->
    <section class="bg-gray-50 py-16 px-5">
        <div class="contenedor mx-auto text-center">
            <h2 class="text-2xl font-bold mb-4">¿Necesitas ayuda con tu proyecto digital?</h2>
            <p class="text-gray-600 mb-8">Nuestro equipo de especialistas en hosting y streaming está disponible 24/7.</p>
            <a
                href="https://wa.me/593991220769"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-[#25D366] hover:bg-[#1ebe5a] text-white font-bold py-3 px-8 rounded-full transition-colors"
            >
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                </svg>
                Consultar por WhatsApp
            </a>
        </div>
    </section>

    <Footer />
</Layout>

<style lang="scss">
    .blog-header {
        background-color: #0e141b;
        background-image: linear-gradient(135deg, #1e1b3d 0%, #0e141b 50%, #19322e 100%);
    }

    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
