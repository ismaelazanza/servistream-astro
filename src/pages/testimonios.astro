---
import Layout from "../layouts/Layout.astro";
import Top from "../components/Top.astro";
import Menu from "../components/Menu.astro";
import MobileMenu from "../components/MobilMenu.astro";
import Footer from "../components/Footer.astro";
import Breadcrumb from "../components/Breadcrumb.astro";

const reviews = [
    {
        author: "Carlos Castillo",
        location: "Quito, Ecuador",
        rating: 5,
        date: "2024-02-15",
        category: "Hosting Linux",
        text: "Llevamos 2 años con ServiStream y el servicio ha sido impecable. El soporte responde en minutos por WhatsApp, algo que nunca encontré en otros proveedores. Nuestra página carga rápido y no hemos tenido caídas.",
        company: "Castillo Consultoría"
    },
    {
        author: "Gabriela Torres",
        location: "Guayaquil, Ecuador",
        rating: 5,
        date: "2024-01-20",
        category: "Radio Online",
        text: "Tenemos nuestra radio online desde hace 3 años con SonicPanel. El panel es muy fácil de usar y el AutoDJ nunca nos ha fallado. Llegamos a 300 oyentes simultáneos en eventos especiales sin problemas.",
        company: "Radio Costavisión"
    },
    {
        author: "Andrés Vásquez",
        location: "Cuenca, Ecuador",
        rating: 5,
        date: "2024-03-05",
        category: "Hosting Cloud",
        text: "Migré mi tienda WooCommerce desde otro hosting y la diferencia es brutal. El tiempo de carga bajó de 6 segundos a menos de 2. Las ventas aumentaron notablemente al mejorar la experiencia del cliente.",
        company: "Alivinatu"
    },
    {
        author: "María José Ruiz",
        location: "Loja, Ecuador",
        rating: 5,
        date: "2024-02-28",
        category: "Dominio y Hosting",
        text: "Como diseñadora web, necesito un hosting confiable para los sitios de mis clientes. ServiStream me ofrece exactamente eso: uptime excelente, cPanel intuitivo y soporte cuando lo necesito. Recomiendo el plan reseller.",
        company: "Ruiz Diseño Web"
    },
    {
        author: "Roberto Chiriboga",
        location: "Ambato, Ecuador",
        rating: 5,
        date: "2024-01-10",
        category: "Streaming TV",
        text: "Implementamos la solución de TV streaming para nuestro canal local. El equipo de ServiStream nos acompañó en todo el proceso técnico. Ahora llegamos a espectadores de todo el mundo por internet.",
        company: "Multicanal"
    },
    {
        author: "Pepe Simancas",
        location: "Quito, Ecuador",
        rating: 5,
        date: "2024-03-18",
        category: "Hosting Reseller",
        text: "Comencé como reseller hace un año y ya tengo 40 clientes activos. El panel WHM funciona perfectamente y el soporte me ayuda cuando algún cliente tiene problemas técnicos. Excelente negocio.",
        company: "Pepe Simancas"
    }
];

const reviewSchema = {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "ServiStream",
    "url": "https://servistream.net",
    "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5",
        "reviewCount": reviews.length.toString(),
        "bestRating": "5",
        "worstRating": "1"
    },
    "review": reviews.map(r => ({
        "@type": "Review",
        "author": {
            "@type": "Person",
            "name": r.author
        },
        "reviewRating": {
            "@type": "Rating",
            "ratingValue": r.rating.toString(),
            "bestRating": "5"
        },
        "datePublished": r.date,
        "reviewBody": r.text,
        "itemReviewed": {
            "@type": "LocalBusiness",
            "name": "ServiStream"
        }
    }))
};

const breadcrumbItems = [
    { label: "Inicio", href: "/" },
    { label: "Testimonios" }
];
---

<Layout
    title="Testimonios de Clientes — ServiStream Ecuador"
    description="Lee las opiniones reales de clientes de ServiStream en Ecuador. Casos de éxito en hosting web, radio streaming, hosting cloud y más servicios digitales."
    schema={reviewSchema}
>
    <header class="testimonios-header">
        <Top />
        <div class="hidden lg:block"><Menu /></div>
        <div class="pt-4 lg:hidden"><MobileMenu /></div>

        <div class="contenedor mx-auto px-5 py-4">
            <Breadcrumb items={breadcrumbItems} />
        </div>

        <div class="contenedor mx-auto text-center py-16 px-5">
            <p class="text-white text-sm font-semibold bg-[#00b285] inline-block px-4 py-1 rounded-full mb-6 uppercase tracking-widest">
                Clientes Satisfechos
            </p>
            <h1 class="text-white text-4xl font-bold pb-4 md:text-5xl">
                Lo que dicen nuestros clientes
            </h1>
            <p class="text-white text-lg max-w-2xl mx-auto">
                Empresas, emprendedores y agencias de todo Ecuador confían en ServiStream para su presencia digital.
            </p>
            <!-- Rating summary -->
            <div class="flex items-center justify-center gap-3 mt-8">
                <div class="flex items-center gap-1">
                    {[1,2,3,4,5].map(() => (
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="#FFD700">
                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                        </svg>
                    ))}
                </div>
                <span class="text-white font-bold text-xl">5.0</span>
                <span class="text-gray-300 text-sm">({reviews.length} reseñas verificadas)</span>
            </div>
        </div>
    </header>

    <!-- Grid de testimonios -->
    <section class="contenedor mx-auto px-5 py-20">
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
            {reviews.map((review) => (
                <article class="bg-white rounded-xl border border-gray-200 p-6 hover:border-[#00b285] hover:shadow-lg transition-all ease-out">
                    <!-- Rating stars -->
                    <div class="flex items-center gap-1 mb-4">
                        {[1,2,3,4,5].map((star) => (
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill={star <= review.rating ? "#FFD700" : "#E5E7EB"}>
                                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                            </svg>
                        ))}
                        <span class="text-xs text-[#00b285] font-semibold ml-2 uppercase tracking-wider">{review.category}</span>
                    </div>

                    <!-- Review text -->
                    <blockquote class="text-gray-600 text-sm leading-relaxed mb-5 italic">
                        "{review.text}"
                    </blockquote>

                    <!-- Author -->
                    <div class="flex items-center gap-3 border-t border-gray-100 pt-4">
                        <div class="w-10 h-10 rounded-full bg-[#00b285] flex items-center justify-center text-white font-bold text-sm flex-shrink-0">
                            {review.author.charAt(0)}
                        </div>
                        <div>
                            <p class="font-semibold text-gray-900 text-sm">{review.author}</p>
                            <p class="text-gray-500 text-xs">{review.company} · {review.location}</p>
                        </div>
                    </div>
                </article>
            ))}
        </div>
    </section>

    <!-- CTA para dejar reseña -->
    <section class="bg-gray-50 py-16 px-5">
        <div class="contenedor mx-auto text-center max-w-2xl">
            <h2 class="text-2xl font-bold mb-3">¿Eres cliente de ServiStream?</h2>
            <p class="text-gray-600 mb-8">Tu opinión ayuda a otros emprendedores ecuatorianos a tomar la mejor decisión. Déjanos tu reseña en Google.</p>
            <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
                <a
                    href="https://wa.me/593991220769"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 bg-[#25D366] hover:bg-[#1ebe5a] text-white font-bold py-3 px-8 rounded-full transition-colors"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                    </svg>
                    Compartir experiencia por WhatsApp
                </a>
                <a
                    href="/contacto/"
                    class="inline-flex items-center gap-2 border-2 border-[#00b285] text-[#00b285] hover:bg-[#00b285] hover:text-white font-bold py-3 px-8 rounded-full transition-colors"
                >
                    Más información
                </a>
            </div>
        </div>
    </section>

    <!-- Logos de tipos de clientes -->
    <section class="contenedor mx-auto px-5 py-16">
        <p class="text-center text-gray-400 text-sm font-semibold uppercase tracking-widest mb-10">Confían en ServiStream</p>
        <div class="grid grid-cols-2 gap-6 md:grid-cols-4 text-center">
            <div class="flex flex-col items-center gap-2">
                <div class="w-14 h-14 bg-[#e8faf5] rounded-full flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00b285" stroke-width="2">
                        <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
                    </svg>
                </div>
                <p class="text-sm font-semibold text-gray-700">Empresas</p>
                <p class="text-xs text-gray-400">+200 activas</p>
            </div>
            <div class="flex flex-col items-center gap-2">
                <div class="w-14 h-14 bg-[#e8faf5] rounded-full flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00b285" stroke-width="2">
                        <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
                    </svg>
                </div>
                <p class="text-sm font-semibold text-gray-700">Agencias Web</p>
                <p class="text-xs text-gray-400">+50 agencias</p>
            </div>
            <div class="flex flex-col items-center gap-2">
                <div class="w-14 h-14 bg-[#e8faf5] rounded-full flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00b285" stroke-width="2">
                        <circle cx="12" cy="12" r="2"/><path d="M16.24 7.76a6 6 0 0 1 0 8.49m-8.48-.01a6 6 0 0 1 0-8.49m11.31-2.82a10 10 0 0 1 0 14.14m-14.14 0a10 10 0 0 1 0-14.14"/>
                    </svg>
                </div>
                <p class="text-sm font-semibold text-gray-700">Radios Online</p>
                <p class="text-xs text-gray-400">+100 radios</p>
            </div>
            <div class="flex flex-col items-center gap-2">
                <div class="w-14 h-14 bg-[#e8faf5] rounded-full flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00b285" stroke-width="2">
                        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
                    </svg>
                </div>
                <p class="text-sm font-semibold text-gray-700">Tiendas Online</p>
                <p class="text-xs text-gray-400">+80 ecommerce</p>
            </div>
        </div>
    </section>

    <Footer />
</Layout>

<style lang="scss">
    .testimonios-header {
        background-color: #0e141b;
        background-image: linear-gradient(135deg, #1e1b3d 0%, #0e141b 50%, #0d2a1f 100%);
    }
</style>
